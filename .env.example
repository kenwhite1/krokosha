# --- Крокоша - environment -------------------------------------------------
# Copy to .env for local dev (or set these in Railway -> Variables).
# With NO BOT_TOKEN the server runs in DEV MODE: auth is stubbed to a single
# local user. Perfect for local playtesting (solo vs bots needs no server at all).

# From @BotFather (/newbot). Required in production.
BOT_TOKEN=

# Public HTTPS origin of the deployed app (Railway gives you one),
# e.g. https://krokosha-production.up.railway.app
# Used for the Telegram webhook + the "Играть" web_app button.
APP_URL=

# The bot's @username without the @ (for invite / room deep links).
BOT_USERNAME=krokosha_play_bot

# Secret path segment for the Telegram webhook (any random string).
WEBHOOK_SECRET=change-me-to-something-random

# Signs session JWTs (any long random string).
JWT_SECRET=change-me-to-a-long-random-string

# SQLite location. On Railway, point this at the mounted volume, e.g. /data
DATA_DIR=./data

# Port (Railway sets this automatically).
PORT=3000
